{
  "name": "docuflow-desktop-agent",
  "version": "0.1.3",
  "description": "DocuFlow Desktop Agent — time tracking, activity monitoring, and screenshot capture",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-port.js 9000",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "dist:win": "node scripts/dist-win.js",
    "dist:win:debug": "node scripts/dist-win.js --debug",
    "dist": "node scripts/dist-win.js",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.docuflow.agent",
    "productName": "DocuFlow Desktop Agent",
    "copyright": "Copyright © 2024 DocuFlow",
    "directories": {
      "output": "release"
    },
    "artifactName": "DocuFlowAgentSetup.exe",
    "compression": "normal",
    "win": {
      "target": "nsis",
      "executableName": "docuflow-agent"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DocuFlow Desktop Agent",
      "uninstallDisplayName": "DocuFlow Desktop Agent",
      "differentialPackage": false
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-deb": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.0.0"
  }
}
